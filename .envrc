#!/usr/bin/env bash

# Export Gemini API key for testing
export GEMINI_FREE_API_KEY=your-api-key-here

# Set up logging level for development
export RUST_LOG=info,hal=debug

# Use local database for testing
export HAL_DATABASE_URL=file:index.db?mode=rwc

# Set up OpenTelemetry endpoint for development
export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
